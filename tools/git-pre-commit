#!/usr/bin/env bash
# Auto-run the pytest suite before every commit.
# Skip with `git commit --no-verify` when you really need to bypass.
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTEST="$REPO_ROOT/venv/bin/python -m pytest"

# Bail early with a clear message if the venv isn't available — better
# than a cryptic interpreter error.
if [ ! -x "$REPO_ROOT/venv/bin/python" ]; then
    echo "pre-commit: venv/bin/python not found; skipping tests."
    echo "  (re-create venv or commit with --no-verify to bypass.)"
    exit 0
fi

echo "pre-commit: running pytest…"
cd "$REPO_ROOT"
if ! $PYTEST -q --tb=short; then
    echo
    echo "pre-commit: ❌ tests failed — commit aborted."
    echo "  Fix the failures, or use 'git commit --no-verify' to bypass."
    exit 1
fi

echo "pre-commit: ✅ all tests pass."
